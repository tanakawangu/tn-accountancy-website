# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender address — must be from a domain verified in your Resend account
# e.g. noreply@tandnaccountancy.co.uk
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Recipient — the business inbox that receives enquiries
CONTACT_TO_EMAIL=info@tandnaccountancy.co.uk

# Send an automatic acknowledgement reply to the client (true/false)
ENABLE_AUTO_REPLY=true

# Node environment
NODE_ENV=production

# Port — Render sets this automatically; leave blank locally to use 3000
PORT=
